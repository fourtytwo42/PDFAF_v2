{
  "appId": "com.pdfaf.desktop",
  "productName": "PDFAF",
  "copyright": "Copyright (c) PDFAF",
  "electronVersion": "36.3.1",
  "npmRebuild": false,
  "asar": false,
  "artifactName": "PDFAF-${version}-${arch}.${ext}",
  "forceCodeSigning": false,
  "directories": {
    "output": "apps/desktop/dist-packaged"
  },
  "files": [
    "package.json",
    "dist/**/*",
    "python/**/*",
    "apps/desktop/dist/**/*",
    "apps/desktop/assets/**/*",
    "apps/pdf-af-web/.next/standalone/**/*",
    "apps/pdf-af-web/.next/static/**/*",
    "apps/pdf-af-web/public/**/*"
  ],
  "extraResources": [
    {
      "from": "apps/desktop/.runtime/win32-x64",
      "to": "runtime",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "executableName": "PDFAF",
    "publisherName": "PDFAF",
    "signAndEditExecutable": true,
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "dir",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "apps/desktop/assets/tray.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": false,
    "createStartMenuShortcut": true,
    "deleteAppDataOnUninstall": false,
    "artifactName": "PDFAF-Setup-${version}-${arch}.${ext}",
    "shortcutName": "PDFAF",
    "uninstallDisplayName": "PDFAF"
  }
}
