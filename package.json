{
  "name": "pdfaf-v2",
  "version": "2.0.0",
  "description": "PDF Accessibility Fixer and Grader v2 — general-purpose WCAG 2.1 AA remediation API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "web:dev": "pnpm --filter pdf-af-web dev",
    "web:build": "pnpm --filter pdf-af-web build",
    "web:start": "pnpm --filter pdf-af-web start",
    "build": "tsc --noEmit && tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "benchmark:corpus": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/experiment-corpus-benchmark.ts",
    "benchmark:corpus:node22": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/experiment-corpus-benchmark.ts",
    "benchmark:gate": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage41-benchmark-gate.ts",
    "benchmark:runtime-isolation": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage46-runtime-regression-isolation.ts",
    "benchmark:teams-parity": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage47-teams-parity-diagnostic.ts",
    "benchmark:df-tail": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage48-df-tail-diagnostic.ts",
    "benchmark:edge-mix": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage49-edge-mix-baseline.ts",
    "benchmark:figure-diagnostic": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage50-figure-residual-diagnostic.ts",
    "benchmark:stage50-isolation": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage51-stage50-acceptance-isolation.ts",
    "benchmark:heading-tail": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage52a-heading-tail-diagnostic.ts",
    "benchmark:hidden-heading-parity": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage52b-hidden-heading-parity.ts",
    "benchmark:edge-mix-volatility": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage53-edge-mix-volatility.ts",
    "benchmark:edge-mix-replay": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage54a-edge-mix-replay.ts",
    "benchmark:edge-mix-replay54c": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage54c-instrumented-replay-summary.ts",
    "benchmark:mixed-tail": "npx -y node@22 /usr/bin/pnpm exec tsx scripts/stage56-mixed-tail-diagnostic.ts",
    "adobe:ingest-reports": "tsx scripts/adobe-accreport-ingest.ts",
    "adobe:assert-thresholds": "tsx scripts/adobe-accreport-assert-thresholds.ts",
    "adobe:assert-pdfaf-signals": "tsx scripts/adobe-accreport-assert-pdfaf-signals.ts",
    "ocr:corpus-batch": "tsx scripts/ocr-corpus-inspect-batch.ts",
    "icjia:corpus-batch": "tsx scripts/icjia-audit-corpus-batch.ts",
    "icjia:retry-failed": "tsx scripts/icjia-retry-failed-audits.ts",
    "icjia:aggregate-findings": "tsx scripts/icjia-aggregate-findings.ts",
    "openapi:validate": "swagger-cli validate openapi.yaml",
    "docker:up": "docker compose up --build",
    "docker:llm": "docker compose up llm -d --build"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.3.136",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
