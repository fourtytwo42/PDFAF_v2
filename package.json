{
  "name": "pdfaf-v2",
  "version": "2.0.0",
  "description": "PDF Accessibility Fixer and Grader v2 - general-purpose WCAG 2.1 AA remediation API",
  "author": "PDFAF",
  "type": "module",
  "main": "apps/desktop/dist/main.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "web:dev": "pnpm --filter pdf-af-web dev",
    "web:build": "pnpm --filter pdf-af-web build",
    "web:start": "pnpm --filter pdf-af-web start",
    "desktop:typecheck": "pnpm --filter pdf-af-desktop typecheck",
    "desktop:build": "pnpm --filter pdf-af-desktop build",
    "desktop:native:prepare": "node scripts/desktop/prepare-native-deps.mjs",
    "desktop:runtime:prepare": "node scripts/desktop/prepare-runtime.mjs",
    "desktop:packaged:dev": "pnpm build && pnpm web:build && pnpm desktop:build && pnpm --filter pdf-af-desktop start",
    "desktop:package:dir": "pnpm desktop:native:prepare && pnpm desktop:runtime:prepare && pnpm build && pnpm web:build && pnpm desktop:build && node scripts/desktop/verify-native-deps.mjs && electron-builder --config apps/desktop/electron-builder.json --dir",
    "desktop:package:win": "pnpm desktop:native:prepare && pnpm desktop:runtime:prepare && pnpm build && pnpm web:build && pnpm desktop:build && node scripts/desktop/verify-native-deps.mjs && electron-builder --config apps/desktop/electron-builder.json --win nsis dir && node scripts/desktop/write-artifact-checksums.mjs",
    "build": "tsc --noEmit && tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "adobe:ingest-reports": "tsx scripts/adobe-accreport-ingest.ts",
    "adobe:assert-thresholds": "tsx scripts/adobe-accreport-assert-thresholds.ts",
    "adobe:assert-pdfaf-signals": "tsx scripts/adobe-accreport-assert-pdfaf-signals.ts",
    "ocr:corpus-batch": "tsx scripts/ocr-corpus-inspect-batch.ts",
    "icjia:corpus-batch": "tsx scripts/icjia-audit-corpus-batch.ts",
    "icjia:retry-failed": "tsx scripts/icjia-retry-failed-audits.ts",
    "icjia:aggregate-findings": "tsx scripts/icjia-aggregate-findings.ts",
    "openapi:validate": "swagger-cli validate openapi.yaml",
    "docker:up": "docker compose up --build",
    "docker:llm": "docker compose up llm -d --build"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.3.136",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "electron-builder": "^24.13.3",
    "supertest": "^7.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
