PORT=6200
NODE_ENV=development
DB_PATH=./data/pdfaf.db
MAX_FILE_SIZE_MB=100
MAX_CONCURRENT_ANALYSES=5
QPDF_TIMEOUT_MS=60000

# Phase 5 — rate limits (per IP, requests per window)
RATE_LIMIT_ANALYZE_MAX=30
RATE_LIMIT_ANALYZE_WINDOW_MS=60000
RATE_LIMIT_REMEDIATE_MAX=10
RATE_LIMIT_REMEDIATE_WINDOW_MS=60000
# Set to 1 in tests / stress runs to disable rate limiting
PDFAF_DISABLE_RATE_LIMIT=

# Phase 5 — wall-clock request timeouts (ms); 0 disables
REQUEST_TIMEOUT_ANALYZE_MS=120000
REQUEST_TIMEOUT_REMEDIATE_MS=300000

# Phase 5 — health LLM probe timeout (ms)
HEALTH_LLM_PROBE_TIMEOUT_MS=3000

# Override Python analysis script path (default: ./python/pdf_analysis_helper.py under cwd)
PDFAF_PYTHON_SCRIPT=

# pdf_ua_compliance: fail list-structure checklist when total Acrobat-style violations >= this (default 1)
# PDF_UA_LIST_VIOLATION_FAIL_THRESHOLD=1
# Python `repair_list_li_wrong_parent`: max LI→L wraps per mutation call (default 32)
# PDFAF_MAX_LIST_LI_REPAIR_PER_CALL=32

# Remediation: default 5 rounds (env REMEDIATION_MAX_ROUNDS). Optional Ghostscript font embed (finalization) when
# PDFAF_AUTO_EMBED_ENCODING=1 and Python flags encodingRisk fonts, or PDFAF_EMBED_FONTS=1 (force). Requires `gs` on PATH.
# PDFAF_AUTO_EMBED_ENCODING=
# PDFAF_EMBED_FONTS=1

# OCR (optional) — `ocr_scanned_pdf` remediation tool (ocrmypdf + Tesseract)
# PDFAF_OCRMYPDF_BIN=ocrmypdf
# PDFAF_OCR_TIMEOUT_SEC=1800
# PDFAF_OCR_MUTATION_TIMEOUT_MS=2700000
# PDFAF_OCR_LANGUAGES=eng+fra
# PDFAF_OCR_NATIVE_ELIGIBLE_MAX_TEXT_CHARS=0
# Cap text_extractability when Producer/Creator looks OCR-generated (default 100 = finding only; e.g. 88 to penalize)
# PDFAF_OCR_METADATA_TEXT_EXTRACTABILITY_CAP=100
# OCR corpus batch script: minimum final score (default 95; use 96 for strictly >95 — may not reach on some OCR PDFs)
# PDFAF_OCR_BATCH_TARGET_SCORE=95

# Phase 3+ LLM — either run the model inside this process OR point at an external OpenAI-compatible server.

# Option A — embedded Gemma 4 E2B instruct (llama.cpp llama-server):
#   Weights card (Safetensors): https://huggingface.co/google/gemma-4-E2B-it
#   llama-server needs GGUF; defaults use Unsloth Q4_K_M (smaller disk than ggml-org Q8): https://huggingface.co/unsloth/gemma-4-E2B-it-GGUF
#   Requires `llama-server` on PATH (or set LLAMA_SERVER_BIN, e.g. ./llama.cpp/build/bin/llama-server after cmake build).
#   PDFAF_RUN_LOCAL_LLM=1
#   PDFAF_LLAMA_PORT=1234
#   GEMMA4_HF_REPO=unsloth/gemma-4-E2B-it-GGUF
#   GEMMA4_GGUF_FILE=gemma-4-E2B-it-Q4_K_M.gguf
#   (Higher quality: ggml-org/gemma-4-E2B-it-GGUF + gemma-4-E2B-it-Q8_0.gguf — larger download.)
#   PDFAF_LLAMA_READY_TIMEOUT_MS=600000
# Leave OPENAI_COMPAT_BASE_URL empty so the app spawns llama-server and sets OPENAI_* automatically.

# Option B — external server (e.g. `docker compose up llm -d`, or any OpenAI-compatible host):
#   OPENAI_COMPAT_BASE_URL=http://127.0.0.1:1234/v1
#   OPENAI_COMPAT_API_KEY=local-dev-any-string
#   OPENAI_COMPAT_MODEL=<exact id from GET …/v1/models>
#   Or set OPENAI_COMPAT_MODEL_AUTO=1 to pick the first id from /v1/models at startup (Docker stack uses this).

PDFAF_RUN_LOCAL_LLM=
PDFAF_LLAMA_PORT=1234
GEMMA4_HF_REPO=unsloth/gemma-4-E2B-it-GGUF
GEMMA4_GGUF_FILE=gemma-4-E2B-it-Q4_K_M.gguf
# Use a recent llama.cpp build (Gemma 4 needs arch support). Example: prebuilt b8783 unpacked under ./data/llama-bin/
LLAMA_SERVER_BIN=llama-server
PDFAF_LLAMA_READY_TIMEOUT_MS=600000

OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
# When 1 and base URL is set (not embedded), first model id from GET …/v1/models is copied into OPENAI_COMPAT_MODEL.
OPENAI_COMPAT_MODEL_AUTO=
# External / default hint — embedded mode overwrites OPENAI_COMPAT_MODEL from llama-server /v1/models.
OPENAI_COMPAT_MODEL=google/gemma-4-E2B-it
OPENAI_COMPAT_FALLBACK_BASE_URL=
OPENAI_COMPAT_FALLBACK_API_KEY=
OPENAI_COMPAT_FALLBACK_MODEL=google/gemma-4-E2B-it

# Phase 3 semantic tuning
SEMANTIC_REQUEST_TIMEOUT_MS=120000
SEMANTIC_REQUEST_CONCURRENCY=2
SEMANTIC_MIN_FIGURE_CONFIDENCE=0.6
SEMANTIC_MAX_FIGURE_CANDIDATES=96
SEMANTIC_FIGURE_BATCH_SIZE=6
# Re-analyze between passes until no proposals or max passes
SEMANTIC_REMEDIATE_FIGURE_PASSES=10
SEMANTIC_REMEDIATE_PROMOTE_PASSES=4
SEMANTIC_PAGE_RENDER_MAX_PX=768
SEMANTIC_PAGE_JPEG_QUALITY=82
SEMANTIC_MAX_IMAGE_BYTES=92160
SEMANTIC_LAYOUT_MAX_PAGES=20
SEMANTIC_LAYOUT_REPEAT_MIN_PAGES=2
SEMANTIC_LAYOUT_REPEAT_MIN_TEXT_LEN=4
SEMANTIC_LAYOUT_Y_NORM_BUCKET=0.04
SEMANTIC_LAYOUT_HEADER_YNORM_MIN=0.72
SEMANTIC_LAYOUT_FOOTER_YNORM_MAX=0.28
SEMANTIC_LAYOUT_BAND_PAD_PT=4
SEMANTIC_PROMOTE_LAYOUT_TEXT_MIN_LEN=8
SEMANTIC_FIGURE_PROMPT_MAX_CAPTIONS_PER_PAGE=6
SEMANTIC_FIGURE_PROMPT_MAX_BAND_LINES_PER_PAGE=4
SEMANTIC_REGRESSION_TOLERANCE=1
SEMANTIC_MIN_HEADING_CONFIDENCE=0.65
SEMANTIC_MAX_HEADING_CANDIDATES=48
SEMANTIC_HEADING_BATCH_SIZE=8
SEMANTIC_HEADING_REQUEST_CONCURRENCY=2
SEMANTIC_MIN_PROMOTE_CONFIDENCE=0.60
SEMANTIC_MAX_PROMOTE_CANDIDATES=80
SEMANTIC_PROMOTE_BATCH_SIZE=8
SEMANTIC_PROMOTE_REQUEST_CONCURRENCY=2
# Max pages scanned for /MCID operators in Python analysis (mirrors bridge env PDFAF_SEMANTIC_MCID_MAX_PAGES)
SEMANTIC_MCID_MAX_PAGES=50
# Optional: fixed /Alt string for informative figures that still have none after repair_alt_text_structure (defaults: MCID-only leaf Figure → "Table (page N)", else "Illustration (page N)")
PDFAF_MISSING_FIGURE_ALT=
# Max successful apply outcomes per remediate run for set_figure_alt_text / mark_figure_decorative (planner repeats)
PDFAF_MAX_FIGURE_ALT_MUTATIONS_PER_RUN=500
# Phase 3c-c: opt-in untagged heading pass on any Marked native_tagged PDF (uses retag_struct_as_heading; default off)
PDFAF_SEMANTIC_UNTAGGED_TIER2=
# When 1, /v1/remediate logs semantic pass skippedReason summary to stdout (debug).
PDFAF_SEMANTIC_DEBUG_LOG=
# Phase 3c-c experimental: semanticUntaggedHeadings, semanticUntaggedHeadingTimeoutMs

# Optional post-remediate Ghostscript font embed (ICIJA text_extractability / Acrobat Character encoding)
# PDFAF_EMBED_FONTS=1   — always run gs rewrite after remediate (when gs succeeds)
# PDFAF_AUTO_EMBED_ENCODING=1 — run gs only when analysis reports fonts[].encodingRisk (non-embedded or legacy missing ToUnicode)
# PDFAF_GS_BIN=gs
